<!DOCTYPE html>
<html lang="en">

  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Feedback Application</title>
    <link rel="stylesheet" href="/css/formcss/login.css">

  </head>

  <body>
  <form action="/login" method="POST" class="container">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div>
      <h1>Login</h1>
  
      <% if (errors && errors.length) { %>
        <div class="error-box">
          <% errors.forEach(function(err) { %>
            <p>
              <%= err %>
            </p>
            <% }) %>
        </div>
        <% } %>
  
          <input type="email" placeholder="Email" name="email" value="<%= oldInput?.email || '' %>" required>
          <div class="password-field">
            <input id="loginPassword" type="password" placeholder="Password" name="password" required>
            <button type="button" class="toggle-password" data-target="loginPassword"
              aria-label="Show password">Show</button>
          </div>
          <button>Log In</button>
    </div>
    <p>don't have an account ? <a href="/signup">Sign Up</a></p>
  </form>

    <script src="/js/formlogic/login.js"></script>
  </body>

</html>
