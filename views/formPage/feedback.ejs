<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Feedback</title>
  <link rel="stylesheet" href="/feedback.css">
</head>

<body>
  <main class="feedback-card">
    <h1>Feedback</h1>

    <div class="top-actions">
      <button type="button" class="btn btn-add">Add Feedback</button>
      <button type="button" class="btn btn-edit">Edit Feedback</button>
    </div>

    <label for="feedbackText">Your Feedback:</label>
    <textarea id="feedbackText" placeholder="Write your feedback here..."></textarea>

    <button type="button" class="btn btn-submit">Submit</button>
  </main>
</body>

</html>
