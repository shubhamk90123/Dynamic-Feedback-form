<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Feedback Application - Register</title>
  <link rel="stylesheet" href="/output.css">
</head>
<body class="min-h-screen bg-gradient-to-br from-slate-50 to-blue-100 font-sans text-slate-800 flex items-center justify-center p-4">

  <form action="/signup" method="POST" class="w-full max-w-sm bg-white/80 backdrop-blur-md border border-slate-200 rounded-xl shadow-lg p-8">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    
    <h1 class="text-2xl font-bold tracking-tight text-center mb-6">Register</h1>

    <% if (errors && errors.length) { %>
      <div class="mb-5 p-3 bg-red-50 border border-red-200 text-red-600 rounded-lg text-sm text-center">
        <% errors.forEach(function(err) { %>
          <p class="m-0"><%= err %></p>
        <% }) %>
      </div>
    <% } %>

    <input type="text" placeholder="Username" name="username" value="<%= oldInput?.username || '' %>" required
      class="w-full mb-4 px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition bg-white/50">
    
    <input type="email" placeholder="Email" name="email" value="<%= oldInput?.email || '' %>" required
      class="w-full mb-4 px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition bg-white/50">
    
    <select name="role" required class="w-full mb-4 px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition bg-white/50 text-slate-600">
      <option value="Select role" selected disabled>Select Role</option>
      <option value="user">User</option>
      <option value="admin">Admin</option>
    </select>
    
    <div class="relative mb-4">
      <input id="signUpPassword" type="password" placeholder="Password" name="password" required
        class="w-full px-4 py-2.5 pr-14 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition bg-white/50">
      <button type="button" class="absolute top-1/2 right-3 -translate-y-1/2 text-sm font-semibold text-blue-600 hover:text-blue-800 transition focus:outline-none" data-target="signUpPassword" aria-label="Show password">Show</button>
    </div>
    
    <div class="relative mb-6">
      <input id="confirmPassword" name="confirmPassword" type="password" placeholder="Confirm Password" required
        class="w-full px-4 py-2.5 pr-14 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition bg-white/50">
      <button type="button" class="absolute top-1/2 right-3 -translate-y-1/2 text-sm font-semibold text-blue-600 hover:text-blue-800 transition focus:outline-none" data-target="confirmPassword" aria-label="Show password">Show</button>
    </div>
    
    <button type="submit"
      class="w-full py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white font-semibold rounded-lg shadow-md hover:shadow-lg transition active:scale-[0.98]">
      Sign Up
    </button>

    <p class="mt-6 text-center text-sm text-slate-500">
      Already have an account? <a href="/login" class="text-blue-600 font-semibold hover:underline">Login</a>
    </p>
  </form>

  <script src="/js/formlogic/signUp.js"></script>
</body>
</html>