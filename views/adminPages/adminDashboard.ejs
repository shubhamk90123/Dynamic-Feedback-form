<!DOCTYPE html>
<html lang="en">

  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Feedback Dashboard</title>
    <link rel="stylesheet" href="/admindashboard.css">
  </head>

  <body>
    <div class="dashboard-card">
      <h1>Admin Feedback Dashboard</h1>

      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Feedback</th>
            <th>Date</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>1</td>
            <td>This is a great product! Highly recommended.</td>
            <td>2024-08-09</td>
            <td class="action-cell">
              <button type="button">View</button>
              <button type="button">Edit</button>
              <button type="button">Delete</button>
            </td>
          </tr>
          <tr>
            <td>2</td>
            <td>I had some issues with the service, but customer support was helpful.</td>
            <td>2024-08-08</td>
            <td class="action-cell">
              <button type="button">View</button>
              <button type="button">Edit</button>
              <button type="button">Delete</button>
            </td>
          </tr>
        </tbody>
      </table>
       
      <a href="/login" class="logout-link">Log Out</a>
    </div>
  </body>

</html>