<!DOCTYPE html>
<html lang="en">

  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Feedback</title>
    <link rel="stylesheet" href="/css/usercss/userFeedback.css">
  </head>

  <body>
    <form class="feedback-card" action="/user/userFeedback" method="POST">
      <h1>Feedback</h1>

      <label for="feedbackText">Enter Your Feedback</label>
      <textarea id="feedbackText" name="feedback" placeholder="Write your feedback here..." required></textarea>

      <button type="submit" class="btn btn-submit">Submit</button>
      <a href="/user/userDashboard" class="link">Back to Dashboard</a>
    </form>
  </body>

</html>
