<!DOCTYPE html>
<html lang="en">

  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Feedback Dashboard</title>
    <link rel="stylesheet" href="/css/usercss/userDashboard.css">
  </head>

  <body>
    <form class="dashboard-card" method="POST">
      <h1>User Feedback Dashboard</h1>

      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Feedback</th>
            <th>Date</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (feedbackData && feedbackData.length) { %>
            <% feedbackData.forEach(function(item, index) { %>
              <tr>
                <td>
                  <%= index + 1 %>
                </td>
                <td>
                  <%= item.feedback %>
                </td>
                <td>
                  <%= new Date().toLocaleDateString() %>
                </td>
                <td class="action-cell">

                  <button type="button">Edit</button>
                  <button type="button">Delete</button>
                </td>
              </tr>
              <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="4">No feedback submitted yet.</td>
                  </tr>
                  <% } %>
        </tbody>
      </table>
      <div>
        <a href="/user/userFeedback" class="link">Add Feedback</a>
        <a href="/login" class="link">Log Out</a>
      </div>

    </form>
  </body>

</html>